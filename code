def add_item():
    name = name_entry.get().strip()
    price = price_entry.get().strip()
    desc = desc_entry.get().strip()
    cat = cat_var.get()

    if not name:
        flash(name_entry, "#c0392b")
        messagebox.showwarning("Name error", "Name is empty")

from tkinter import *
from tkinter import ttk, messagebox


class Item:
    name: str
    price: int
    description: str
    category: str

    def __init__(self, name, price, description, category):
        self.name = name
        self.price = price
        self.description = description
        self.category = category

    def __str__(self):
        return f"{self.name} {self.price}"


categories = ["Електроніка", "Одяг", "Їжа", "Спорт", "Автотовари", "інше"]

Items: list[Item] = []


def labeled_entry(parent, label_text, row, var=None):
    Label(parent, text=label_text,
          bg="#1a1a1a", fg="#888888", font=("Courier New", 8), anchor="w").grid(row=row * 2, column=0, sticky="w",
                                                                                padx=10, pady=(8, 0))

    e = Entry(parent,
              bg="#111111", fg="#f0f0f0",
              insertbackground="#e8c84a",
              relief="flat", bd=0,
              highlightthickness=1,
              highlightbackground="#2e2e2e",
              font=("Courier New", 10),
              textvariable=var)
    e.grid(row=row * 2 + 1, column=0, sticky="ew", padx=10, pady=(2, 0))
    return e


def flash(widget, color="#e8c84a"):
    orig = widget.cget("highlightbackground")
    widget.config(highlightbackground=color, highlightthickness=2)
    widget.after(400, lambda: widget.config(highlightbackground=orig, highlightthickness=1))


